---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { generateBreadcrumbs, generateService, generateFAQPage } from '../data/schema';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImage from '../assets/marielle/marielle_yogapose_attributes.jpg';

const faqItems = [
  {
    question: 'Hoe ver is Yogapracht vanaf Oisterwijk?',
    answer: 'Yogapracht in Hilvarenbeek ligt op 10 minuten rijden vanaf Oisterwijk centrum. Via de Oisterwijksedreef of het Beekse Bergen-kruispunt ben je er snel, met gratis parkeren voor de deur.',
  },
  {
    question: 'Zijn de lessen geschikt bij overprikkeling?',
    answer: 'De lessen bij Yogapracht zijn bijzonder geschikt bij overprikkeling en chronische spanning. Hatha-rajayoga activeert het parasympathisch zenuwstelsel — het deel dat verantwoordelijk is voor rust en herstel. Mariëlle heeft zich hierin aanvullend gespecialiseerd.',
  },
  {
    question: 'Kan ik ook privélessen aan huis krijgen in Oisterwijk?',
    answer: 'Privélessen kunnen ook bij jou thuis in Oisterwijk worden gegeven. Mariëlle neemt alle benodigde materialen mee en stemt de les volledig af op jouw situatie en wensen.',
  },
];
---

<BaseLayout
  title={`Yoga voor inwoners van Oisterwijk | ${siteConfig.name}`}
  description="Yoga vlakbij Oisterwijk — hatha-rajayoga bij Yogapracht in Hilvarenbeek. 10 minuten rijden. Persoonlijke begeleiding, kleine groepen en een gratis proefles."
  schemas={[
    generateBreadcrumbs([{ name: 'Yoga Oisterwijk', url: '/yoga-oisterwijk' }]),
    generateService({
      name: 'Yoga voor inwoners van Oisterwijk',
      description: 'Hatha-rajayoga bij Yogapracht in Hilvarenbeek, op 10 minuten rijden vanaf Oisterwijk. Kleine groepen met persoonlijke aandacht.',
      url: '/yoga-oisterwijk',
      serviceType: 'Yoga lessen',
    }),
    generateFAQPage(faqItems.map(f => ({ question: f.question, answer: f.answer }))),
  ]}
  breadcrumbs={[{ label: 'Yoga Oisterwijk' }]}
>
  <section class="py-12 md:py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <div class="rounded-card overflow-hidden mb-10">
        <Image
          src={heroImage}
          alt="Yoga bij Yogapracht — rustige setting dicht bij Oisterwijk"
          widths={[480, 768, 1024]}
          sizes="(max-width: 768px) 100vw, 768px"
          class="w-full h-56 md:h-72 object-cover"
          loading="eager"
        />
      </div>
      <h1 class="font-heading text-3xl md:text-4xl text-primary mb-6">Yoga voor inwoners van Oisterwijk</h1>
      <p class="text-lg text-text-muted leading-relaxed mb-8">
        Yogapracht in Hilvarenbeek biedt hatha-rajayoga lessen voor inwoners van Oisterwijk. De studio ligt op 10 minuten rijden en biedt groepslessen van maximaal acht deelnemers, privélessen op maat en stoelyoga. Gediplomeerd yogadocent Mariëlle van der Geest is gespecialiseerd in yoga bij overprikkeling en stress — de reden waarom veel deelnemers uit Oisterwijk specifiek voor Yogapracht kiezen.
      </p>

      <div class="prose prose-lg">
        <h2>Rustige setting, dicht bij huis</h2>
        <p>
          De studio van Yogapracht ligt aan de Hakvoortseweg in Hilvarenbeek — via de Oisterwijksedreef of het Beekse Bergen-kruispunt ben je er in een paar minuten. De sfeer is vergelijkbaar met wat je in Oisterwijk waardeert: rustig, groen en zonder haast.
        </p>
        <p>
          Doordat de lessen maximaal acht deelnemers tellen, heeft docent Mariëlle van der Geest de ruimte om te kijken of een houding goed bij jouw lichaam past. Ze corrigeert niet om te corrigeren, maar om je te helpen comfortabeler te bewegen.
        </p>

        <h2>Speciaal geschikt bij overprikkeling en stress</h2>
        <p>
          Veel deelnemers uit Oisterwijk komen naar Yogapracht omdat ze last hebben van overprikkeling of chronische spanning. De lessen zijn gebaseerd op hatha-rajayoga: een methode die het parasympathisch zenuwstelsel activeert. Dat is het deel van je zenuwstelsel dat verantwoordelijk is voor rust en herstel.
        </p>
        <p>
          Elke les sluit af met shavasana — een diepe ontspanning van 10 tot 15 minuten. Deelnemers beschrijven het als het stilste moment van hun week.
        </p>

        <h2>Het lesaanbod</h2>
        <ul>
          <li><strong>Groepslessen</strong> — wekelijks, geschikt voor beginners en gevorderden</li>
          <li><strong>Privélessen</strong> — op maat, ook aan huis in Oisterwijk</li>
          <li><strong>Stoelyoga</strong> — yogalessen op een stoel, toegankelijk bij fysieke beperkingen</li>
        </ul>

        <h2>Probeer het vrijblijvend</h2>
        <p>
          Je eerste les is gratis. Kom kennismaken zonder verplichting — alles wat je nodig hebt is aanwezig in de studio. Gratis parkeren voor de deur.
        </p>
      </div>

      {/* ── E-E-A-T ── */}
      <div class="mt-10 bg-primary/5 rounded-card p-8">
        <h2 class="font-heading text-xl text-text mb-3">Gediplomeerde yogadocent</h2>
        <p class="text-text-muted leading-relaxed">
          De lessen worden gegeven door Mariëlle van der Geest, gediplomeerd hatha-rajayoga docent opgeleid bij <a href="https://www.deblikopener.com/" target="_blank" rel="noopener" class="text-accent hover:text-accent-dark underline">De Blikopener</a> (erkend door de <a href="https://www.europeanunionofyoga.com/" target="_blank" rel="noopener" class="text-accent hover:text-accent-dark underline">Europese Yoga Unie</a>). Lid van de Vereniging Yogadocenten Nederland (VYN), met aanvullende specialisaties in yoga bij overprikkeling, chronische pijn en stoelyoga.
        </p>
      </div>

      <FAQAccordion
        title="Veelgestelde vragen — yoga vanuit Oisterwijk"
        items={faqItems.map(f => ({ q: f.question, a: f.answer }))}
        pageType="service"
        pageSlug="/yoga-oisterwijk"
        compact={true}
      />

      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-6 py-3 bg-accent text-white font-semibold rounded-button hover:bg-accent-dark transition-colors"
        >
          Gratis proefles aanvragen
        </a>
        <a
          href="/diensten"
          class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary text-primary font-semibold rounded-button hover:bg-primary hover:text-white transition-colors"
        >
          Bekijk alle diensten
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
