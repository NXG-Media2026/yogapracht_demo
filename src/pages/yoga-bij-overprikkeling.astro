---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { siteConfig } from '../data/site';
import { generateBreadcrumbs, generateFAQPage } from '../data/schema';
import heroImage from '../assets/marielle/backgroundimage_marielle.jpg';
import profileImage from '../assets/marielle/marielle_profile_image.jpg';
import yogaPose from '../assets/marielle/marielle_yogapose_sideways.jpg';

const faqItems = [
  {
    q: 'Wat is overprikkeling precies?',
    a: 'Overprikkeling ontstaat wanneer je zenuwstelsel meer prikkels ontvangt dan het kan verwerken. Het uit zich in innerlijke onrust, vermoeidheid ondanks voldoende slaap, prikkelbaarheid en het gevoel constant "aan" te staan.',
  },
  {
    q: 'Hoe helpt yoga bij overprikkeling?',
    a: 'Yoga activeert het parasympathische zenuwstelsel — het deel dat verantwoordelijk is voor rust en herstel. Door bewuste ademhaling, zachte houdingen en meditatie leer je je zenuwstelsel te kalmeren en sneller terug te keren naar een rustige staat.',
  },
  {
    q: 'Heb ik yoga-ervaring nodig?',
    a: 'De oefeningen zijn toegankelijk voor iedereen, ook als je nog nooit yoga hebt gedaan. De nadruk ligt op rust en bewustwording, niet op fysieke uitdaging.',
  },
  {
    q: 'Hoe snel merk ik verschil bij overprikkeling?',
    a: 'De meeste deelnemers merken na de eerste les al dat ze rustiger worden. Na vier tot zes weken regelmatig oefenen ervaren zij structureel minder innerlijke onrust, betere slaap en meer draagkracht in het dagelijks leven.',
  },
  {
    q: 'Welke yogavormen biedt Yogapracht aan bij overprikkeling?',
    a: 'Mariëlle biedt privélessen, groepslessen en een online videoles specifiek gericht op overprikkeling. Elke vorm combineert zachte houdingen, ademhalingsoefeningen en meditatie — afgestemd op het kalmeren van je zenuwstelsel.',
  },
];
---

<BaseLayout
  title={`Yoga bij overprikkeling — rust en herstel | ${siteConfig.name}`}
  description="Yoga bij overprikkeling in Hilvarenbeek. Kalmeer je zenuwstelsel met hatha-rajayoga bij Yogapracht. Privélessen, groepslessen en online videoles."
  schemas={[
    generateBreadcrumbs([{ name: 'Yoga bij overprikkeling', url: '/yoga-bij-overprikkeling' }]),
    generateFAQPage(faqItems.map(f => ({ question: f.q, answer: f.a }))),
  ]}
  breadcrumbs={[{ label: 'Yoga bij overprikkeling' }]}
>

  {/* ── Hero ── */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroImage}
        alt="Yoga bij overprikkeling — rust en herstel bij Yogapracht in Hilvarenbeek"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-primary-dark/75"></div>
    </div>
    <div class="relative py-20 md:py-28 lg:py-36">
      <div class="max-w-4xl mx-auto px-4 md:px-6">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight max-w-3xl">
          Yoga bij overprikkeling
        </h1>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10 max-w-xl">
          Van voortdurend dragen en innerlijke onrust naar rustig aanwezig zijn bij jezelf. Door zachte yoga leer je je zenuwstelsel kalmeren.
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a
            href="/masterclass"
            class="inline-flex items-center px-8 py-4 text-base font-medium text-text-inverse bg-accent hover:bg-accent-dark transition-colors rounded-button shadow-lg"
          >
            Gratis masterclass volgen
          </a>
          <a
            href="/aanbod/videoles-overprikkeling"
            class="inline-flex items-center px-8 py-4 text-base font-medium text-white border-2 border-white/60 hover:bg-white/10 transition-colors rounded-button"
          >
            Bekijk de videoles
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ── Herkenning ── */}
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text mb-6">Overprikkeling herkennen</h2>
      <p class="text-lg text-text-muted leading-relaxed mb-6">
        Herken je dit? Je bent moe, maar kunt niet ontspannen. Je hoofd staat nooit stil. Geluiden, drukte en prikkels waar anderen geen last van hebben, kosten jou enorm veel energie. Je draagt voortdurend — voor je gezin, je werk, anderen — en vergeet jezelf.
      </p>
      <p class="text-text-muted leading-relaxed mb-8">
        Overprikkeling is geen zwakte. Het is een signaal van je zenuwstelsel dat het meer prikkels ontvangt dan het kan verwerken. En het goede nieuws: je kunt je zenuwstelsel trainen om sneller terug te keren naar rust.
      </p>

      <div class="bg-bg-alt rounded-card p-6 md:p-8">
        <h3 class="font-heading text-xl text-text mb-4">Signalen van overprikkeling</h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">&#9679;</span>
            <span class="text-text-muted">Constant gevoel van innerlijke onrust</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">&#9679;</span>
            <span class="text-text-muted">Moe maar niet kunnen ontspannen</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">&#9679;</span>
            <span class="text-text-muted">Snel geïrriteerd of emotioneel</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">&#9679;</span>
            <span class="text-text-muted">Moeite met concentreren</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">&#9679;</span>
            <span class="text-text-muted">Hoofdpijn of spanning in nek en schouders</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-primary mt-1">&#9679;</span>
            <span class="text-text-muted">Behoefte om je terug te trekken</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* ── Hoe yoga helpt ── */}
  <section class="py-12 md:py-16 bg-bg-alt">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="w-full md:w-2/5 shrink-0">
          <div class="rounded-card overflow-hidden">
            <Image
              src={yogaPose}
              alt="Hatha-rajayoga houding — yoga bij overprikkeling bij Yogapracht Hilvarenbeek"
              widths={[384, 512]}
              sizes="(max-width: 768px) 100vw, 40vw"
              class="w-full h-auto"
              loading="lazy"
            />
          </div>
        </div>
        <div>
          <h2 class="font-heading text-2xl md:text-3xl text-text mb-6">Hatha-rajayoga als tegenwicht</h2>
          <p class="text-text-muted leading-relaxed mb-4">
            Yoga activeert het parasympathische zenuwstelsel — het systeem dat verantwoordelijk is voor rust en herstel. Door regelmatig te oefenen train je je lichaam om sneller te schakelen van "aan" naar "uit".
          </p>
          <p class="text-text-muted leading-relaxed">
            Bij Yogapracht werken we met zachte houdingen die spanning loslaten, ademhalingsoefeningen die je zenuwstelsel kalmeren, en meditatie die je helpt om uit je hoofd en in je lichaam te komen. Elke les sluit af met een diepe ontspanning waarin alles mag landen.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── Wat het oplevert ── */}
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text mb-8">Resultaten die deelnemers ervaren</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          </div>
          <div>
            <h3 class="font-heading text-lg text-text mb-1">Minder innerlijke onrust</h3>
            <p class="text-sm text-text-muted">Je leert sneller schakelen van spanning naar ontspanning.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          </div>
          <div>
            <h3 class="font-heading text-lg text-text mb-1">Betere nachtrust</h3>
            <p class="text-sm text-text-muted">Door bewuste ontspanning vóór het slapengaan.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          </div>
          <div>
            <h3 class="font-heading text-lg text-text mb-1">Meer draagkracht</h3>
            <p class="text-sm text-text-muted">Je herstelt sneller en kunt meer aan zonder jezelf te verliezen.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          </div>
          <div>
            <h3 class="font-heading text-lg text-text mb-1">Bewuster ademen</h3>
            <p class="text-sm text-text-muted">De adem als anker — altijd beschikbaar om tot rust te komen.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Over Mariëlle + specialisatie ── */}
  <section class="py-12 md:py-16 bg-bg-alt">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
        <div class="w-32 h-32 shrink-0 rounded-full overflow-hidden border-4 border-primary-light/30">
          <Image
            src={profileImage}
            alt="Mariëlle van der Geest — yogadocent gespecialiseerd in overprikkeling bij Yogapracht Hilvarenbeek"
            width={128}
            height={128}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <h2 class="font-heading text-2xl text-text mb-3">Begeleiding door Mariëlle van der Geest</h2>
          <p class="text-text-muted leading-relaxed mb-3">
            Mariëlle is gediplomeerd hatha-rajayoga docent en heeft zich in 2023 gespecialiseerd in yoga en preventie van overprikkeling. Zij combineert deze kennis met jarenlange ervaring in het begeleiden van mensen met lichamelijke en mentale klachten.
          </p>
          <p class="text-text-muted leading-relaxed">
            Haar aanpak is persoonlijk en zonder druk. Of je nu in een groep wilt oefenen of liever één-op-één werkt — Mariëlle stemt de lessen af op wat jij nodig hebt.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── Mogelijkheden ── */}
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text mb-8">Mogelijkheden bij Yogapracht</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <a href="/masterclass" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <span class="text-xs font-medium uppercase tracking-wider text-accent mb-2 block">Gratis</span>
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Masterclass overprikkeling</h3>
          <p class="text-sm text-text-muted mb-3">Gratis live masterclass over yoga bij overprikkeling. Leer hoe je je zenuwstelsel kalmeert en ga direct aan de slag.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Aanmelden &rarr;</span>
        </a>
        <a href="/aanbod/videoles-overprikkeling" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <span class="text-xs font-medium uppercase tracking-wider text-accent mb-2 block">Online — &euro;27</span>
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Videoles overprikkeling</h3>
          <p class="text-sm text-text-muted mb-3">Direct beschikbare videoles + PDF met oefeningen voor thuis. Op je eigen tempo, wanneer het jou uitkomt.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Bekijk &rarr;</span>
        </a>
        <a href="/diensten/privelessen" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <span class="text-xs font-medium uppercase tracking-wider text-accent mb-2 block">Persoonlijk</span>
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Privéles op maat</h3>
          <p class="text-sm text-text-muted mb-3">Eén-op-één begeleiding volledig afgestemd op jouw situatie. In de studio of bij jou thuis.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Meer info &rarr;</span>
        </a>
        <a href="/diensten/groepslessen" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <span class="text-xs font-medium uppercase tracking-wider text-accent mb-2 block">In de studio</span>
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Groepsles bijwonen</h3>
          <p class="text-sm text-text-muted mb-3">Wekelijkse hatha-rajayoga in kleine groep. Gratis proefles om te ervaren hoe het voelt.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Meer info &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  {/* ── FAQ ── */}
  <div class="bg-bg-alt">
    <FAQAccordion
      title="Veelgestelde vragen over yoga bij overprikkeling"
      items={faqItems}
      locale="nl"
      pageType="overprikkeling"
      pageSlug="/yoga-bij-overprikkeling"
    />
  </div>

</BaseLayout>
