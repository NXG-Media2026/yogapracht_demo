---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { siteConfig } from '../data/site';
import { getCollection, getEntry } from 'astro:content';
import { generateLocalBusiness, generateWebSite, generateAggregateRating, generateFAQPage, generateFounderPerson, generateReviewSnippets } from '../data/schema';
import heroImage from '../assets/marielle/backgroundimage_marielle.jpg';
import profileImage from '../assets/marielle/marielle_profile_image.jpg';
import ctaImage from '../assets/marielle/marielle_yogapose.jpg';
import yogaPoseSideways from '../assets/marielle/marielle_yogapose_sideways.jpg';
import bulletIcon from '../assets/marielle/bullet-logo-groen.png';

const testimonials = await getCollection('testimonials');
const homepage = await getEntry('settings', 'homepage');
const hp = homepage?.data ?? {};

const allFaqs = await getCollection('faqs');
const homepageFaqs = allFaqs
  .filter(f => f.data.page === 'home')
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const homepageFaq = homepageFaqs.map(f => ({
  q: f.data.question,
  a: f.data.answer,
}));
---

<BaseLayout
  title={`${siteConfig.name} — hatha-rajayoga in Hilvarenbeek`}
  description="Yogapracht Hilvarenbeek — hatha-rajayoga bij overprikkeling, stress en spanning. Groepslessen, privélessen en online yoga door gediplomeerd docent Mariëlle. Gratis proefles."
  schemas={[
    generateLocalBusiness(),
    generateWebSite('nl'),
    generateFounderPerson(),
    generateAggregateRating(testimonials.map(t => ({ rating: t.data.rating ?? 5 }))),
    generateReviewSnippets(testimonials.map(t => ({ name: t.data.name, text: t.data.text, rating: t.data.rating ?? 5 }))),
    generateFAQPage(homepageFaq.map(f => ({ question: f.q, answer: f.a }))),
  ].filter(Boolean)}
>

  {/* ── Hero ── */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroImage}
        alt="Mariëlle van der Geest — hatha-rajayoga yogales bij Yogapracht in Hilvarenbeek"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-primary-dark/70"></div>
    </div>
    <div class="relative py-24 md:py-32 lg:py-40">
      <div class="max-w-4xl mx-auto px-4 md:px-6">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight max-w-2xl">
          {hp.heroTitel ?? 'Yogapracht Hilvarenbeek — rust en balans door hatha-rajayoga'}
        </h1>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10 max-w-xl">
          {hp.heroSubtekst ?? 'In een wereld van drukte en hectiek bied ik je een veilige omgeving om even stil te staan en jezelf een cadeau te geven door middel van yoga.'}
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a
            href="/contact"
            class="inline-flex items-center px-8 py-4 text-base font-medium text-text-inverse bg-accent hover:bg-accent-dark transition-colors rounded-button shadow-lg"
          >
            {hp.heroCtaPrimary ?? 'Gratis proefles aanvragen'}
          </a>
          <a
            href="/diensten"
            class="inline-flex items-center px-8 py-4 text-base font-medium text-white border-2 border-white/60 hover:bg-white/10 transition-colors rounded-button"
          >
            {hp.heroCtaSecondary ?? 'Bekijk de mogelijkheden'}
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ── Introductie ── */}
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="font-heading text-2xl md:text-3xl text-text mb-6">{hp.introTitel ?? 'Yoga in Hilvarenbeek'}</h2>
        <p class="text-lg text-text-muted leading-relaxed mb-4">
          {hp.introTekst ?? 'Yogapracht is de yogapraktijk van Mariëlle van der Geest in Hilvarenbeek. Als gediplomeerd hatha-rajayoga docent begeleidt zij mensen die meer rust, balans en bewustzijn zoeken in hun leven. De lessen zijn gebaseerd op de yogasutra\'s van Patanjali — een tijdloze filosofie die lichaam en geest met elkaar verbindt. Of je nu voor het eerst op een matje stapt of al jaren oefent: bij Yogapracht is er een vorm die bij jou past.'}
        </p>
      </div>
    </div>
  </section>

  {/* ── Wat is hatha-rajayoga ── */}
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text mb-6">Hatha-rajayoga: lichaam en geest in balans</h2>
      <p class="text-text-muted leading-relaxed mb-4">
        Hatha-rajayoga is een traditionele yogavorm die lichaam en geest combineert. Het woord "hatha" verwijst naar het fysieke aspect — houdingen (asana's) en ademhalingsoefeningen (pranayama) — terwijl "raja" zich richt op de geest: concentratie en meditatie. Omdat beide aspecten samenkomen in elke les, ervaren deelnemers niet alleen meer souplesse, maar ook meer mentale rust.
      </p>
      <p class="text-text-muted leading-relaxed mb-6">
        De lessen bij Yogapracht zijn gebaseerd op de Yoga Sūtra's van Patañjali, een Indiase filosoof die duizenden jaren geleden de principes van bewustzijnsontwikkeling vastlegde. Dat betekent dat elke les een vaste structuur volgt: houdingen om het lichaam te openen, ademhalingsoefeningen als brug tussen lichaam en geest, meditatie voor innerlijke stilte, en een diepe ontspanning (shavasana) om af te sluiten.
      </p>
      <h3 class="font-heading text-xl text-text mb-4">Lesopbouw bij een groepsles</h3>
      <ul class="space-y-2 mb-6">
        <li class="flex items-start gap-3">
          <span class="text-accent font-medium mt-0.5">1.</span>
          <span class="text-text-muted"><strong class="text-text">Houdingen (asana's)</strong> — lichamelijke oefeningen waarmee je spanning loslaat en naar binnen reist</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-accent font-medium mt-0.5">2.</span>
          <span class="text-text-muted"><strong class="text-text">Ademhaling (pranayama)</strong> — bewuste ademhalingsoefeningen die het zenuwstelsel kalmeren</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-accent font-medium mt-0.5">3.</span>
          <span class="text-text-muted"><strong class="text-text">Meditatie</strong> — het onafgebroken vasthouden van je concentratie voor innerlijke stilte</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-accent font-medium mt-0.5">4.</span>
          <span class="text-text-muted"><strong class="text-text">Diepe ontspanning (shavasana)</strong> — afsluiting waarin alles mag landen en het lichaam herstelt</span>
        </li>
      </ul>
      <p class="text-text-muted leading-relaxed">
        Elke les duurt ongeveer 75 minuten. Er is geen ervaring nodig om te beginnen, omdat Mariëlle de houdingen aanpast aan het niveau van de deelnemers. Dat maakt de groepslessen geschikt voor zowel beginners als gevorderden. Je kunt altijd een gratis proefles volgen om te ervaren hoe hatha-rajayoga voelt.
      </p>
    </div>
  </section>

  {/* ── Diensten ── */}
  <section class="py-12 md:py-16 bg-bg-alt">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text mb-3">Mogelijkheden bij Yogapracht</h2>
      <p class="text-text-muted mb-8 max-w-2xl">Elke yogavorm heeft dezelfde basis — houdingen, ademhaling, meditatie en ontspanning — maar is afgestemd op een andere situatie.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/diensten/groepslessen" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <Image src={bulletIcon} alt="" width={28} height={28} class="w-7 h-7 mb-3" loading="lazy" aria-hidden="true" />
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Groepslessen</h3>
          <p class="text-sm text-text-muted mb-3">Wekelijkse hatha-rajayoga in een kleine groep. Persoonlijke aandacht en ruimte om in je eigen tempo te oefenen.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Meer info &rarr;</span>
        </a>
        <a href="/diensten/privelessen" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <Image src={bulletIcon} alt="" width={28} height={28} class="w-7 h-7 mb-3" loading="lazy" aria-hidden="true" />
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Privélessen</h3>
          <p class="text-sm text-text-muted mb-3">Persoonlijke begeleiding op maat, in de studio of bij jou thuis. Beschikbaar in Nederlands en Engels.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Meer info &rarr;</span>
        </a>
        <a href="/diensten/stoelyoga" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <Image src={bulletIcon} alt="" width={28} height={28} class="w-7 h-7 mb-3" loading="lazy" aria-hidden="true" />
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Stoelyoga</h3>
          <p class="text-sm text-text-muted mb-3">Alle voordelen van yoga, zittend op een stoel. Toegankelijk voor iedereen, ongeacht mobiliteit.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Meer info &rarr;</span>
        </a>
        <a href="/diensten/bedrijfsyoga" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <Image src={bulletIcon} alt="" width={28} height={28} class="w-7 h-7 mb-3" loading="lazy" aria-hidden="true" />
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Bedrijfsyoga</h3>
          <p class="text-sm text-text-muted mb-3">Yogalessen op de werkvloer voor meer rust en energie bij jouw team. Op locatie in de regio Hilvarenbeek.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Meer info &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  {/* ── Masterclass Banner ── */}
  <section class="relative overflow-hidden bg-primary-dark">
    <div class="absolute inset-0 opacity-20">
      <Image
        src={yogaPoseSideways}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="lazy"
        aria-hidden="true"
      />
    </div>
    <div class="relative py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-4 md:px-6">
        <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
          <div class="flex-1 text-center md:text-left">
            <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-widest text-white bg-accent rounded-full mb-4">Gratis live masterclass</span>
            <h2 class="font-heading text-3xl md:text-4xl text-white mb-4 leading-tight">Yoga bij overprikkeling</h2>
            <p class="text-lg text-white/80 leading-relaxed mb-6 max-w-lg">
              Leer in 45 minuten hoe je zenuwstelsel werkt, waarom je niet tot rust komt en welke yogaoefeningen je direct kunt toepassen. Geen ervaring nodig.
            </p>
            <div class="flex flex-col sm:flex-row items-center md:items-start gap-4">
              <a
                href="/masterclass"
                class="inline-flex items-center px-8 py-4 text-base font-semibold bg-accent hover:bg-accent-dark text-white transition-colors rounded-button shadow-lg"
              >
                Meld je gratis aan
                <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
              <span class="text-sm text-white/60">Inclusief oefeningen voor thuis</span>
            </div>
          </div>
          <div class="w-full md:w-2/5 shrink-0">
            <div class="rounded-card overflow-hidden shadow-2xl border-2 border-white/10">
              <Image
                src={ctaImage}
                alt="Gratis masterclass yoga bij overprikkeling — Yogapracht Hilvarenbeek"
                widths={[384, 512]}
                sizes="(max-width: 768px) 100vw, 40vw"
                class="w-full h-auto"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Wat deelnemers ervaren ── */}
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="w-full md:w-2/5 shrink-0">
          <div class="rounded-card overflow-hidden">
            <Image
              src={yogaPoseSideways}
              alt="Hatha-rajayoga houding door Mariëlle — yoga bij overprikkeling en stress in Hilvarenbeek"
              widths={[384, 512]}
              sizes="(max-width: 768px) 100vw, 40vw"
              class="w-full h-auto"
              loading="lazy"
            />
          </div>
        </div>
        <div>
          <h2 class="font-heading text-2xl md:text-3xl text-text mb-6">Wat deelnemers ervaren na een aantal weken</h2>
          <p class="text-text-muted leading-relaxed mb-6">
            Hatha-rajayoga activeert het parasympathische zenuwstelsel — het deel dat verantwoordelijk is voor rust en herstel. Deelnemers in Hilvarenbeek merken na vier tot zes weken concrete veranderingen:
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span class="text-text-muted">Sneller schakelen van spanning naar ontspanning — ook buiten de les</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span class="text-text-muted">Beter slapen doordat het hoofd eerder stil wordt</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span class="text-text-muted">Minder spanning in nek, schouders en onderrug</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span class="text-text-muted">Bewustere ademhaling als anker in drukke momenten</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              <span class="text-text-muted">Meer ruimte om te kiezen hoe je reageert op prikkels</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* ── Voor wie ── */}
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text mb-6">Voor wie zijn de lessen bij Yogapracht?</h2>
      <p class="text-text-muted leading-relaxed mb-6">
        Mariëlle heeft veertien bijscholingen gevolgd om specifieke doelgroepen gericht te begeleiden. In de studio aan de Hakvoortseweg in Hilvarenbeek biedt zij yoga aan voor:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
        <a href="/yoga-bij-overprikkeling" class="flex items-start gap-3 group">
          <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          <span class="text-text-muted group-hover:text-accent transition-colors"><strong class="text-text">Mensen met overprikkeling of HSP</strong> — leer je zenuwstelsel kalmeren</span>
        </a>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          <span class="text-text-muted"><strong class="text-text">Mensen met chronische pijn</strong> — bewegen zonder het lichaam te belasten</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          <span class="text-text-muted"><strong class="text-text">Zwangeren</strong> — veilig oefenen afgestemd op elke fase</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          <span class="text-text-muted"><strong class="text-text">Ouderen of mensen met beperkte mobiliteit</strong> — via stoelyoga</span>
        </div>
        <a href="/diensten/bedrijfsyoga" class="flex items-start gap-3 group">
          <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          <span class="text-text-muted group-hover:text-accent transition-colors"><strong class="text-text">Bedrijven in de regio Hilvarenbeek</strong> — yoga op de werkvloer</span>
        </a>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          <span class="text-text-muted"><strong class="text-text">Beginners zonder ervaring</strong> — gratis proefles om kennis te maken</span>
        </div>
      </div>
      <div class="bg-bg-alt rounded-card p-6">
        <h3 class="font-heading text-xl text-text mb-4">Waarom Yogapracht</h3>
        <ul class="space-y-2">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            <span class="text-text-muted"><strong class="text-text">Kleine groepen</strong> — maximaal 8 deelnemers voor persoonlijke aandacht</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            <span class="text-text-muted"><strong class="text-text">Gediplomeerd docent</strong> — opgeleid bij <a href="https://www.deblikopener.com" target="_blank" rel="noopener" class="text-accent hover:text-accent-dark underline">de Blikopener</a> met 14 bijscholingen</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            <span class="text-text-muted"><strong class="text-text">Lid van</strong> de <a href="https://www.europeanyogaunion.org" target="_blank" rel="noopener" class="text-accent hover:text-accent-dark underline">Europese Yoga Unie</a> en de Vereniging Yogadocenten Nederland</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            <span class="text-text-muted"><strong class="text-text">Tweetalig</strong> — lessen in het Nederlands en Engels</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* ── Over de founder ── */}
  <section class="py-12 md:py-16 bg-bg-alt">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="w-48 h-48 md:w-56 md:h-56 shrink-0 rounded-full overflow-hidden border-4 border-primary-light/30">
          <Image
            src={profileImage}
            alt="Mariëlle van der Geest — gediplomeerd yogadocent bij Yogapracht in Hilvarenbeek"
            width={224}
            height={224}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="text-center md:text-left">
          <h2 class="font-heading text-2xl md:text-3xl text-text mb-4">Over Mariëlle van der Geest</h2>
          <p class="text-text-muted leading-relaxed mb-3">
            Mariëlle beoefent sinds 2011 hatha-rajayoga en volgde haar yogadocentopleiding bij opleidingsinstituut de Blikopener (2016–2020). Sindsdien heeft zij zich bijgeschoold in veertien specialisaties, waaronder stoelyoga, yoga bij chronische pijn, yoga bij depressie en yoga en preventie van overprikkeling. Dat betekent dat zij deelnemers met uiteenlopende achtergronden en klachten kan begeleiden.
          </p>
          <p class="text-text-muted leading-relaxed mb-6">
            Het is haar zielsmissie om je vanuit plezier, vrijheid en intuïtie yoga te laten beoefenen. Haar verwondering over de pracht van yoga drijft haar om zich hierin continu te verdiepen. Yogapracht is lid van de Europese Yoga Unie en de Vereniging Yogadocenten Nederland, omdat kwaliteit en continue ontwikkeling centraal staan in haar werk.
          </p>
          <a
            href="/over"
            class="inline-flex items-center text-accent hover:text-accent-dark transition-colors font-medium"
          >
            Lees meer over Mariëlle en haar opleidingen
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ── Reviews ── */}
  {testimonials.length > 0 && (
    <section class="py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-4 md:px-6">
        <h2 class="font-heading text-2xl md:text-3xl text-text mb-3">Ervaringen van deelnemers</h2>
        <p class="text-text-muted mb-8">Wat deelnemers zeggen over hun yogalessen bij Yogapracht.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {testimonials.slice(0, 3).map((t) => (
            <TestimonialCard
              name={t.data.name}
              role={t.data.role}
              text={t.data.text}
              rating={t.data.rating}
            />
          ))}
        </div>
        {testimonials.length > 3 && (
          <div class="text-center mt-8">
            <a
              href="/reviews"
              class="inline-flex items-center text-accent hover:text-accent-dark transition-colors font-medium"
            >
              Alle reviews bekijken
              <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  {/* ── CTA Band ── */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={ctaImage}
        alt="Yogahouding hatha-rajayoga — gratis proefles bij Yogapracht in Hilvarenbeek"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-primary-dark/75"></div>
    </div>
    <div class="relative py-20 md:py-28">
      <div class="max-w-4xl mx-auto px-4 md:px-6 text-center">
        <h2 class="font-heading text-3xl md:text-4xl text-white mb-4">
          {hp.ctaBandTitel ?? 'Ervaar zelf de kracht van yoga'}
        </h2>
        <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">
          {hp.ctaBandTekst ?? 'Boek een gratis en vrijblijvende proefles en ontdek wat hatha-rajayoga voor jou kan betekenen. Geen ervaring nodig — alleen de wil om het te proberen.'}
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-8 py-4 text-base font-medium bg-accent hover:bg-accent-dark text-white transition-colors rounded-button shadow-lg"
        >
          {hp.ctaBandKnop ?? 'Gratis proefles aanvragen'}
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  {/* ── Online aanbod ── */}
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text mb-3">Online yoga en verdieping</h2>
      <p class="text-text-muted mb-8 max-w-2xl">Yoga beoefenen op je eigen tempo, wanneer het jou uitkomt. Ideaal als aanvulling op de lessen of als zelfstandige start.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/masterclass" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <span class="text-xs font-medium uppercase tracking-wider text-accent mb-2 block">Gratis</span>
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Masterclass overprikkeling</h3>
          <p class="text-sm text-text-muted mb-3">Gratis live masterclass waarin je leert hoe yoga je zenuwstelsel kalmeert. Inclusief oefeningen om direct mee te beginnen.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Aanmelden &rarr;</span>
        </a>
        <a href="/aanbod/videoles-overprikkeling" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <span class="text-xs font-medium uppercase tracking-wider text-accent mb-2 block">&euro;27</span>
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Videoles overprikkeling</h3>
          <p class="text-sm text-text-muted mb-3">Complete videoles + PDF met oefeningen voor thuis. Leer je zenuwstelsel kalmeren op je eigen tempo.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Bekijk &rarr;</span>
        </a>
        <a href="/yoga-bij-overprikkeling" class="group bg-white rounded-card p-6 border border-border hover:border-primary-light/50 hover:shadow-md transition-all">
          <span class="text-xs font-medium uppercase tracking-wider text-accent mb-2 block">Specialisatie</span>
          <h3 class="font-heading text-lg text-text mb-2 group-hover:text-primary transition-colors">Yoga bij overprikkeling</h3>
          <p class="text-sm text-text-muted mb-3">Alles over hoe hatha-rajayoga helpt bij overprikkeling en HSP. Lees meer over de aanpak en mogelijkheden.</p>
          <span class="text-sm text-accent group-hover:text-accent-dark font-medium">Lees meer &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  {/* ── FAQ ── */}
  <div class="bg-bg-alt">
    <FAQAccordion
      title="Veelgestelde vragen"
      items={homepageFaq}
      locale="nl"
      pageType="homepage"
      pageSlug="/"
    />
  </div>

</BaseLayout>
