---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import { siteConfig } from '../data/site';
import { getCollection } from 'astro:content';
import { generateLocalBusiness, generateWebSite, generateAggregateRating, generateFAQPage } from '../data/schema';
import heroImage from '../assets/marielle/backgroundimage_marielle.jpg';
import profileImage from '../assets/marielle/marielle_profile_image.jpg';
import ctaImage from '../assets/marielle/marielle_yogapose.jpg';
import bulletIcon from '../assets/marielle/bullet-logo-groen.png';

const testimonials = await getCollection('testimonials');

const homepageFaq = [
  {
    q: 'Wat is hatha-rajayoga precies?',
    a: 'Hatha-rajayoga is een vorm van yoga gericht op bewustzijnsontwikkeling. Hathayoga richt zich op het fysieke aspect, terwijl rajayoga zich richt op de geest. De lessen zijn gebaseerd op de wetenschap van de Indiase filosoof Patanjali.',
  },
  {
    q: 'Heb ik ervaring nodig om te beginnen?',
    a: 'Helemaal niet. De lessen zijn geschikt voor iedereen, ongeacht leeftijd of ervaring. Je kunt altijd een gratis proefles volgen om kennis te maken met yoga bij Yogapracht.',
  },
  {
    q: 'Wat kan ik verwachten tijdens een les?',
    a: 'Een les bestaat uit houdingen (asana\'s), ademhalingsoefeningen en meditatie. Elke les wordt afgesloten met een diepe ontspanning (shavasana). De lessen duren ongeveer 75 minuten.',
  },
  {
    q: 'Worden de lessen ook in het Engels gegeven?',
    a: 'De lessen kunnen zowel in het Nederlands als in het Engels gegeven worden. Bij privélessen wordt de taal afgestemd op jouw voorkeur.',
  },
];
---

<BaseLayout
  title={`${siteConfig.name} — ${siteConfig.tagline}`}
  description="Yogapracht in Hilvarenbeek — hatha-rajayoga lessen van gediplomeerd yogadocent Mariëlle van der Geest. Groepslessen, privélessen, stoelyoga en bedrijfsyoga."
  schemas={[
    generateLocalBusiness(),
    generateWebSite('nl'),
    generateAggregateRating(testimonials.map(t => ({ rating: t.data.rating ?? 5 }))),
    generateFAQPage(homepageFaq.map(f => ({ question: f.q, answer: f.a }))),
  ].filter(Boolean)}
>

  {/* ── Hero ── */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroImage}
        alt="Mariëlle van der Geest — hatha-rajayoga yogales bij Yogapracht in Hilvarenbeek"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-primary-dark/70"></div>
    </div>
    <div class="relative py-24 md:py-32 lg:py-40">
      <div class="max-w-4xl mx-auto px-4 md:px-6">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight max-w-2xl">
          Rust, ontspanning en balans door hatha-rajayoga
        </h1>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10 max-w-xl">
          In een wereld van drukte en hectiek bied ik je een veilige omgeving om even stil te staan en jezelf een cadeau te geven door middel van yoga.
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a
            href="/contact"
            class="inline-flex items-center px-8 py-4 text-base font-medium text-text-inverse bg-accent hover:bg-accent-dark transition-colors rounded-button shadow-lg"
          >
            Gratis proefles aanvragen
          </a>
          <a
            href="/over"
            class="inline-flex items-center px-8 py-4 text-base font-medium text-white border-2 border-white/60 hover:bg-white/10 transition-colors rounded-button"
          >
            Over Mariëlle
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ── Diensten / USPs ── */}
  <section class="py-12 md:py-16 bg-bg-alt">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <h2 class="font-heading text-2xl md:text-3xl text-text mb-8">Mogelijkheden</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-card p-6 border border-border">
          <Image src={bulletIcon} alt="" width={28} height={28} class="w-7 h-7 mb-3" loading="lazy" aria-hidden="true" />
          <h3 class="font-heading text-lg text-text mb-2">Groepslessen</h3>
          <p class="text-sm text-text-muted">Reguliere hatha-rajayoga lessen in een kleine groep. Ook Morgenstond Yoga op maandagochtend om 09:00 uur.</p>
        </div>
        <div class="bg-white rounded-card p-6 border border-border">
          <Image src={bulletIcon} alt="" width={28} height={28} class="w-7 h-7 mb-3" loading="lazy" aria-hidden="true" />
          <h3 class="font-heading text-lg text-text mb-2">Privélessen</h3>
          <p class="text-sm text-text-muted">Persoonlijke begeleiding op maat, bij jou thuis of in de studio. Beschikbaar in Nederlands en Engels.</p>
        </div>
        <div class="bg-white rounded-card p-6 border border-border">
          <Image src={bulletIcon} alt="" width={28} height={28} class="w-7 h-7 mb-3" loading="lazy" aria-hidden="true" />
          <h3 class="font-heading text-lg text-text mb-2">Stoelyoga & Bedrijfsyoga</h3>
          <p class="text-sm text-text-muted">Toegankelijke yoga op een stoel of yogalessen op de werkvloer voor meer rust en energie bij jouw team.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ── Over de founder ── */}
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 md:px-6">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="w-48 h-48 md:w-56 md:h-56 shrink-0 rounded-full overflow-hidden border-4 border-primary-light/30">
          <Image
            src={profileImage}
            alt="Mariëlle van der Geest — gediplomeerd yogadocent bij Yogapracht in Hilvarenbeek"
            width={224}
            height={224}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="text-center md:text-left">
          <h2 class="font-heading text-2xl md:text-3xl text-text mb-4">Over Mariëlle</h2>
          <p class="text-lg text-text-muted leading-relaxed mb-6">
            Gediplomeerd hatha-rajayoga docent sinds 2020. Het is mijn zielsmissie om je vanuit plezier, vrijheid en intuïtie yoga te laten beoefenen.
          </p>
          <a
            href="/over"
            class="inline-flex items-center text-accent hover:text-accent-dark transition-colors font-medium"
          >
            Lees meer
            <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ── Reviews ── */}
  {testimonials.length > 0 && (
    <section class="py-12 md:py-16 bg-bg-alt">
      <div class="max-w-4xl mx-auto px-4 md:px-6">
        <h2 class="font-heading text-2xl md:text-3xl text-text mb-8">Ervaringen van deelnemers</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {testimonials.slice(0, 3).map((t) => (
            <TestimonialCard
              name={t.data.name}
              role={t.data.role}
              text={t.data.text}
              rating={t.data.rating}
            />
          ))}
        </div>
        {testimonials.length > 3 && (
          <div class="text-center mt-8">
            <a
              href="/reviews"
              class="inline-flex items-center text-accent hover:text-accent-dark transition-colors font-medium"
            >
              Alle reviews bekijken
              <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  {/* ── CTA Band ── */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={ctaImage}
        alt="Yogahouding hatha-rajayoga — gratis proefles bij Yogapracht in Hilvarenbeek"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-primary-dark/75"></div>
    </div>
    <div class="relative py-20 md:py-28">
      <div class="max-w-4xl mx-auto px-4 md:px-6 text-center">
        <h2 class="font-heading text-3xl md:text-4xl text-white mb-4">
          Ervaar zelf de kracht van yoga
        </h2>
        <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">
          Boek een gratis en vrijblijvende proefles en ontdek wat hatha-rajayoga voor jou kan betekenen.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-8 py-4 text-base font-medium bg-accent hover:bg-accent-dark text-white transition-colors rounded-button shadow-lg"
        >
          Gratis proefles aanvragen
          <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  {/* ── FAQ ── */}
  <div class="bg-bg-alt">
    <FAQAccordion
      title="Veelgestelde vragen"
      items={homepageFaq}
      locale="nl"
      pageType="homepage"
      pageSlug="/"
    />
  </div>

</BaseLayout>
