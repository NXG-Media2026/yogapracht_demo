---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
import { generateBreadcrumbs, generateService, generateFAQPage } from '../data/schema';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImage from '../assets/marielle/backgroundimage_marielle.jpg';

const faqItems = [
  {
    question: 'Hoe ver is Yogapracht vanaf Goirle?',
    answer: 'Yogapracht in Hilvarenbeek ligt op 10 minuten rijden vanaf Goirle centrum. Via de Turnhoutsebaan of N395 ben je er snel, met gratis parkeren voor de deur van de studio.',
  },
  {
    question: 'Biedt Yogapracht ook bedrijfsyoga in Goirle?',
    answer: 'Bedrijfsyoga kan op locatie worden gegeven bij bedrijven in Goirle en omgeving. Mariëlle komt naar de werkplek en past de les aan op de groep — als reguliere yogales of als stoelyoga-variant.',
  },
  {
    question: 'Hoe groot zijn de groepen bij Yogapracht?',
    answer: 'De groepslessen tellen maximaal acht deelnemers. Door deze bewust kleine groepsgrootte is er altijd ruimte voor persoonlijke aandacht en kan Mariëlle houdingen individueel bijsturen.',
  },
];
---

<BaseLayout
  title={`Yoga voor inwoners van Goirle | ${siteConfig.name}`}
  description="Yoga dicht bij Goirle — hatha-rajayoga bij Yogapracht in Hilvarenbeek. 10 minuten rijden. Kleine groepen, rust en persoonlijke begeleiding. Gratis proefles."
  schemas={[
    generateBreadcrumbs([{ name: 'Yoga Goirle', url: '/yoga-goirle' }]),
    generateService({
      name: 'Yoga voor inwoners van Goirle',
      description: 'Hatha-rajayoga bij Yogapracht in Hilvarenbeek, op 10 minuten rijden vanaf Goirle. Kleine groepen met persoonlijke aandacht.',
      url: '/yoga-goirle',
      serviceType: 'Yoga lessen',
    }),
    generateFAQPage(faqItems.map(f => ({ question: f.question, answer: f.answer }))),
  ]}
  breadcrumbs={[{ label: 'Yoga Goirle' }]}
>
  <section class="py-12 md:py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 md:px-6">
      <div class="rounded-card overflow-hidden mb-10">
        <Image
          src={heroImage}
          alt="Yogapracht studio Hilvarenbeek — yogalessen dicht bij Goirle"
          widths={[480, 768, 1024]}
          sizes="(max-width: 768px) 100vw, 768px"
          class="w-full h-56 md:h-72 object-cover"
          loading="eager"
        />
      </div>
      <h1 class="font-heading text-3xl md:text-4xl text-primary mb-6">Yoga voor inwoners van Goirle</h1>
      <p class="text-lg text-text-muted leading-relaxed mb-8">
        Yogapracht in Hilvarenbeek biedt hatha-rajayoga lessen voor inwoners van Goirle. De studio ligt op 10 minuten rijden via de Turnhoutsebaan en biedt groepslessen, privélessen (ook aan huis in Goirle) en bedrijfsyoga op locatie. Gediplomeerd yogadocent Mariëlle van der Geest geeft les in kleine groepen van maximaal acht personen, met een gratis en vrijblijvende proefles.
      </p>

      <div class="prose prose-lg">
        <h2>Yogapracht: net even buiten Goirle</h2>
        <p>
          Sommige deelnemers vertellen dat het ritje naar Hilvarenbeek al onderdeel is van het loslaten. Even de telefoon weg, de blik op het landschap, en bij aankomst stap je een wereld in waar niets hoeft. De studio aan de Hakvoortseweg is klein en stil — geen wachtruimte vol mensen, geen haast.
        </p>

        <h2>Voor wie zijn de lessen geschikt?</h2>
        <p>
          De lessen bij Yogapracht zijn specifiek gericht op mensen die veel prikkels ervaren in het dagelijks leven. Denk aan drukke banen, mantelzorg, of herstel na een burn-out. De yogavorm — hatha-rajayoga — is bewust gekozen omdat het zowel het lichaam als de geest betrekt.
        </p>
        <p>
          Geen acrobatiek, geen wedstrijdelement. Wel: bewuste ademhaling, zachte houdingen en een diepe ontspanning die je lichaam de kans geeft om echt te herstellen.
        </p>

        <h2>Praktische informatie</h2>
        <ul>
          <li><strong>Bereikbaarheid</strong> — via de Turnhoutsebaan of N395, 10 minuten vanaf Goirle centrum</li>
          <li><strong>Parkeren</strong> — gratis voor de deur</li>
          <li><strong>Groepsgrootte</strong> — maximaal 8 personen per les</li>
          <li><strong>Lesduur</strong> — 75 minuten inclusief diepe ontspanning</li>
          <li><strong>Meenemen</strong> — niets, alles is aanwezig</li>
        </ul>

        <h2>Diensten</h2>
        <ul>
          <li><a href="/diensten/groepslessen" class="text-accent hover:text-accent-dark">Groepslessen</a> — wekelijks, open instap</li>
          <li><a href="/diensten/privelessen" class="text-accent hover:text-accent-dark">Privélessen</a> — ook aan huis in Goirle</li>
          <li><a href="/diensten/bedrijfsyoga" class="text-accent hover:text-accent-dark">Bedrijfsyoga</a> — op locatie bij bedrijven in Goirle</li>
        </ul>

        <h2>Gratis kennismaken</h2>
        <p>
          Nog nooit yoga gedaan? Geen probleem. Je eerste les is gratis en volledig vrijblijvend. Mariëlle past alles aan op jouw tempo en mogelijkheden.
        </p>
      </div>

      {/* ── E-E-A-T ── */}
      <div class="mt-10 bg-primary/5 rounded-card p-8">
        <h2 class="font-heading text-xl text-text mb-3">Gediplomeerde yogadocent</h2>
        <p class="text-text-muted leading-relaxed">
          De lessen worden gegeven door Mariëlle van der Geest, gediplomeerd hatha-rajayoga docent opgeleid bij <a href="https://www.deblikopener.com/" target="_blank" rel="noopener" class="text-accent hover:text-accent-dark underline">De Blikopener</a> (erkend door de <a href="https://www.europeanunionofyoga.com/" target="_blank" rel="noopener" class="text-accent hover:text-accent-dark underline">Europese Yoga Unie</a>). Lid van de Vereniging Yogadocenten Nederland (VYN), met aanvullende specialisaties in yoga bij overprikkeling, chronische pijn en stoelyoga.
        </p>
      </div>

      <FAQAccordion
        title="Veelgestelde vragen — yoga vanuit Goirle"
        items={faqItems.map(f => ({ q: f.question, a: f.answer }))}
        pageType="service"
        pageSlug="/yoga-goirle"
        compact={true}
      />

      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-6 py-3 bg-accent text-white font-semibold rounded-button hover:bg-accent-dark transition-colors"
        >
          Gratis proefles aanvragen
        </a>
        <a
          href="/diensten"
          class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary text-primary font-semibold rounded-button hover:bg-primary hover:text-white transition-colors"
        >
          Bekijk alle diensten
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
