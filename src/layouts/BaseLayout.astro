---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { siteConfig } from '../data/site';
import { getTrackingScript } from '../lib/analytics';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  schemas?: string[];
}

const {
  title,
  description,
  canonical = `${siteConfig.url}${Astro.url.pathname}`,
  ogImage,
  ogType,
  noindex = false,
  schemas = [],
} = Astro.props;
---

<!DOCTYPE html>
<html lang="nl" class="scroll-smooth">
<head>
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    ogType={ogType}
    noindex={noindex}
    schemas={schemas}
    locale="nl"
  />

  <script is:inline set:html={getTrackingScript()} />
</head>
<body class="bg-bg text-text min-h-screen flex flex-col">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-button focus:text-sm"
  >
    Ga naar inhoud
  </a>

  <Header currentPath={Astro.url.pathname} />

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <Footer />

  <CookieConsent />

  <script is:inline>
  (function(){
    if(!('IntersectionObserver' in window)) {
      document.querySelectorAll('.js-reveal').forEach(function(el){el.classList.add('is-visible')});
      return;
    }
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){e.target.classList.add('is-visible');io.unobserve(e.target)}
      });
    },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.js-reveal').forEach(function(el){io.observe(el)});
  })();
  </script>
</body>
</html>
