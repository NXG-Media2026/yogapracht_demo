---
import { t } from '../i18n/utils';
import type { Locale } from '../data/site';
import type { PageType } from '../lib/analytics';
import { trackOnClick } from '../lib/analytics';

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  title?: string;
  items: FAQItem[];
  locale?: Locale;
  pageType?: PageType;
  pageSlug?: string;
  compact?: boolean;
  maxItems?: number;
}

const {
  title,
  items,
  locale = 'nl',
  pageType = 'homepage',
  pageSlug = '/',
  compact = false,
  maxItems,
} = Astro.props;

const heading = title ?? t('faq.heading', locale);
const sectionPadding = compact ? 'pt-8 md:pt-10' : 'py-16 md:py-24 lg:py-32';
const headingMargin = compact ? 'mb-6 md:mb-8' : 'mb-12 md:mb-16';
const displayItems = maxItems ? items.slice(0, maxItems) : items;
---

<section class:list={[sectionPadding, 'bg-bg']}>
  <div class="max-w-3xl mx-auto px-4 md:px-6">
    <h2 class:list={['font-heading text-2xl md:text-3xl text-text text-center', headingMargin, compact && 'lg:text-3xl', !compact && 'lg:text-4xl']}>
      {heading}
    </h2>

    <div class="space-y-3">
      {displayItems.map((item) => (
        <details
          class="group border border-border rounded-card overflow-hidden"
          onclick={trackOnClick('faq_expand', { page_type: pageType, page_slug: pageSlug, locale })}
        >
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none text-text hover:text-accent transition-colors">
            {/* Real <h3> heading so AI crawlers and assistive tech find the question
                in the document outline. Visual weight stays subtle — citability,
                not typography hierarchy. */}
            <h3 class="font-body font-medium text-base leading-snug m-0">
              {item.q}
            </h3>
            <svg
              class="w-5 h-5 shrink-0 text-text-muted transition-transform duration-200 group-open:rotate-45"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </summary>
          <div class="px-6 pb-6 prose prose-sm max-w-none text-text-muted prose-p:leading-relaxed prose-a:text-accent-dark prose-a:underline prose-a:underline-offset-2">
            <p set:html={item.a} />
          </div>
        </details>
      ))}
    </div>

  </div>
</section>
