# ─── Public (exposed at build time, safe for frontend) ───────────

# Analytics
PUBLIC_GA_MEASUREMENT_ID=
PUBLIC_GSC_VERIFICATION_ID=
PUBLIC_META_PIXEL_ID=

# External service URLs
PUBLIC_CALENDLY_URL=
PUBLIC_SKOOL_URL=
PUBLIC_WEBINAR_URL=

# Email capture — provider name only (no secrets)
PUBLIC_EMAIL_PROVIDER=placeholder

# ─── Server-only secrets (NOT exposed in frontend) ──────────────
# These are for serverless functions / Cloudflare Workers only.
# Never prefix with PUBLIC_ — they must stay server-side.

# MailerLite (if PUBLIC_EMAIL_PROVIDER=mailerlite)
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Kit / ConvertKit (if PUBLIC_EMAIL_PROVIDER=kit)
KIT_API_KEY=
KIT_FORM_ID=
